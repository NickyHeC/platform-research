# Dedalus API Key (get from https://dedalus.dev/dashboard/api-keys)
DEDALUS_API_KEY=dsk-live-your-key-here

# Local defuddle-mcp server URL (start with: cd defuddle-mcp && uv run python -m src.main)
DEFUDDLE_MCP_URL=http://127.0.0.1:8080/mcp

# Hosted defuddle-mcp server slug on Dedalus marketplace
DEFUDDLE_MCP_SERVER=nickyhec/defuddle-mcp

# LLM model (used for hosted scraping complement and PROJECT.md generation)
MODEL=anthropic/claude-sonnet-4-20250514

# Agent timeout in seconds (default 600 = 10 minutes)
AGENT_TIMEOUT=600

# Output directory for scraped docs (default: docs)
# OUTPUT_DIR=docs
